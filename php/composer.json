{
    "name": "ontraport/mcp-server",
    "description": "Ontraport MCP Server — PHP implementation",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "php-mcp/server": "^3.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "OntraportMcp\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OntraportMcp\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "start": "php server.php"
    }
}
