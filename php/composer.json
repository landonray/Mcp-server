{
    "name": "ontraport/mcp-server",
    "description": "Ontraport MCP Server — PHP implementation",
    "type": "project",
    "require": {
        "php": ">=7.4",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "OntraportMcp\\": "src/"
        },
        "files": [
            "src/Compat.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "OntraportMcp\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "start": "php server.php"
    }
}
